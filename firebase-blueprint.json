{
  "entities": {
    "User": {
      "title": "User",
      "description": "Wholesale customer profiles and custom pricing rules",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Email address of the customer"
        },
        "companyName": {
          "type": "string",
          "description": "Business or company name"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"],
          "description": "Access approval status"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Profile registration timestamp"
        },
        "approvedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Approval timestamp"
        },
        "customPricing": {
          "type": "object",
          "description": "Map of product IDs to custom prices specifically for this customer"
        },
        "allowedProducts": {
          "type": "array",
          "description": "List of product IDs that this user is explicitly allowed to view and order (if products are restricted)"
        }
      },
      "required": ["email", "companyName", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Wholesale products offered",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "sku": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "imageUrl": {
          "type": "string"
        },
        "baseWholesalePrice": {
          "type": "number"
        },
        "isRestricted": {
          "type": "boolean"
        },
        "quantityBreaks": {
          "type": "array"
        }
      },
      "required": ["name", "sku", "baseWholesalePrice", "isRestricted"]
    },
    "Order": {
      "title": "Order",
      "description": "Wholesale customer orders, representing invoices and packing slips",
      "type": "object",
      "properties": {
        "customerId": {
          "type": "string"
        },
        "customerEmail": {
          "type": "string"
        },
        "companyName": {
          "type": "string"
        },
        "items": {
          "type": "array"
        },
        "subtotal": {
          "type": "number"
        },
        "gstAmount": {
          "type": "number"
        },
        "totalAmount": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["pending_payment", "paid", "shipped", "cancelled"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["customerId", "customerEmail", "companyName", "items", "subtotal", "gstAmount", "totalAmount", "status", "createdAt"]
    },
    "RateBreakProfile": {
      "title": "RateBreakProfile",
      "description": "Reusable pricing template with per-product quantity breaks assigned to customers",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Profile name e.g. 'Wholesale Partner'"
        },
        "description": {
          "type": "string",
          "description": "Optional description of this pricing tier"
        },
        "productBreaks": {
          "type": "object",
          "description": "Map of productId to array of QuantityBreak objects"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this profile was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this profile was last updated"
        },
        "createdBy": {
          "type": "string",
          "description": "Admin user ID who created this profile"
        }
      },
      "required": ["name", "productBreaks", "createdAt", "updatedAt", "createdBy"]
    },
    "WeightBreakTemplate": {
      "title": "WeightBreakTemplate",
      "description": "Quantity-based pricing tier that can be assigned to customers (max 10 per system)",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Template name e.g. 'Tier 1 - Starter'"
        },
        "description": {
          "type": "string",
          "description": "Optional description of this weight break"
        },
        "quantityBreaks": {
          "type": "array",
          "description": "Array of QuantityBreak objects for this tier"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this template was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this template was last updated"
        },
        "createdBy": {
          "type": "string",
          "description": "Admin user ID who created this template"
        }
      },
      "required": ["name", "quantityBreaks", "createdAt", "updatedAt", "createdBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Customer records, roles, and pricing"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Wholesale catalog items"
    },
    "/rateBreakProfiles/{profileId}": {
      "schema": "RateBreakProfile",
      "description": "Reusable pricing templates with quantity breaks"
    },
    "/weightBreakTemplates/{templateId}": {
      "schema": "WeightBreakTemplate",
      "description": "Quantity-based pricing tiers assignable to customers (max 10)"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Wholesale transactions, packing slips, and billing"
    }
  }
}
