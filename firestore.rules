rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == "lew@desmoproducts.com.au" || 
         request.auth.token.email == "1@1.com" ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isApproved() {
      return isSignedIn() && 
        (isAdmin() || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == "approved");
    }

    // 2. Users Collection Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isSignedIn();
      
      // Creating a profile: Status MUST be pending on self-registration unless admin
      allow create: if isSignedIn() && isOwner(userId) && (
        isAdmin() || (
          request.resource.data.status == "pending" &&
          request.resource.data.email == request.auth.token.email
        )
      );
        
      // Updating a profile: Admin can update anything. Owner can update company name, but cannot approve themselves or change custom pricing.
      allow update: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.status == resource.data.status && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['customPricing', 'status', 'allowedProducts', 'email', 'createdAt']))
      );
    }

    // 3. Products Collection Rules
    match /products/{productId} {
      // Any authenticated user can read public products. Restricted products can only be read by admins or explicitly allowed customers.
      allow get: if isSignedIn() && (
        resource.data.isRestricted == false || 
        isAdmin() || 
        (isApproved() && productId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.allowedProducts)
      );
      
      // Listing products: Anyone can list products to see the catalog
      allow list: if true;
      
      // Writing products is Admin only
      allow write: if isAdmin();
    }

    // 4. Rate Break Profiles Collection Rules
    match /rateBreakProfiles/{profileId} {
      // Approved customers can read profiles assigned to them; admins can read all
      allow get: if isAdmin() || (
        isApproved() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('rateBreakProfileId') == profileId
      );
      
      // Customers can list profiles to see available options (admin view)
      allow list: if isAdmin() || isApproved();
      
      // Only admins can create/update/delete rate break profiles
      allow write: if isAdmin();
    }

    // 4b. Weight Break Templates Collection Rules
    match /weightBreakTemplates/{templateId} {
      // Approved customers can read templates; admins can read all
      allow get: if isApproved() || isAdmin();
      allow list: if isApproved() || isAdmin();
      
      // Only admins can create/update/delete weight break templates
      allow write: if isAdmin();
    }

    // 5. Orders Collection Rules
    match /orders/{orderId} {
      // Customers can read their own orders; admins can read all orders
      allow get: if isAdmin() || (isApproved() && resource.data.customerId == request.auth.uid);
      allow list: if isAdmin() || (isApproved() && resource.data.customerId == request.auth.uid);
      
      // Creating an order: Admins can create for anyone; approved customers can create quotes or invoices for themselves
      allow create: if isAdmin() || (
        isApproved() && 
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.documentType in ["QUOTE", "INVOICE"] &&
        request.resource.data.status in ["pending_approval", "approved", "pending_payment", "quote_requested"]
      );
        
      // Updating an order: Admin can change status (paid/shipped). Customers can accept finalized quotes.
      allow update: if isAdmin() || (
        isApproved() && 
        resource.data.customerId == request.auth.uid &&
        (
          (resource.data.documentType == "QUOTE" &&
           resource.data.status == "quote_finalized" &&
           request.resource.data.status in ["approved", "declined"] &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'approvedAt'])) ||
          (resource.data.status == "pending_payment" &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'notes']) &&
           request.resource.data.status == "cancelled")
        )
      );
      
      allow delete: if isAdmin();
    }

    // 6. Settings Collection Rules
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
